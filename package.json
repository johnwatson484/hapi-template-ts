{
  "name": "hapi-template-ts",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "scripts": {
    "pretest": "npm run test:lint && npm run typecheck",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:lint": "eslint",
    "test:debug": "vitest --inspect-brk --no-file-parallelism",
    "typecheck": "tsc",
    "start": "node src/index.ts",
    "start:dev": "node --watch --watch-path=src src/index.ts",
    "start:debug": "node --watch --watch-path=src --inspect=0.0.0.0 src/index.ts",
    "docker:start": "docker compose up",
    "docker:debug": "docker compose run --rm --service-ports hapi-template-ts npm run start:debug",
    "docker:test": "mkdir -p test-output 2>/dev/null || true && docker compose -f compose.yaml -f compose.test.yaml run --build --rm hapi-template-ts",
    "docker:test:watch": "docker compose -f compose.yaml -f compose.test.yaml run --build --rm hapi-template-ts npm run test:watch"
  },
  "author": "John Watson",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@hapi/boom": "10.0.1",
    "@hapi/crumb": "9.0.1",
    "@hapi/hapi": "21.4.9",
    "@hapi/inert": "7.1.1",
    "@hapi/scooter": "8.0.0",
    "@hapi/vision": "7.0.3",
    "blankie": "5.0.0",
    "convict": "6.2.5",
    "convict-format-with-validator": "6.2.0",
    "hapi-pino": "12.1.0",
    "joi": "18.2.1",
    "nunjucks": "3.2.4"
  },
  "devDependencies": {
    "@types/convict": "6.1.6",
    "@types/convict-format-with-validator": "6.0.5",
    "@types/hapi__crumb": "7.3.7",
    "@types/node": "22.13.10",
    "@types/nunjucks": "3.2.6",
    "@vitest/coverage-v8": "4.1.8",
    "blipp": "4.0.2",
    "eslint": "9.39.1",
    "neostandard": "0.11.4",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
